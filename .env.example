# ─────────────────────────────────────────────────────────────────────────────
# FRONTEND — Plantilla de variables de entorno
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a git.
# ─────────────────────────────────────────────────────────────────────────────

# URL del backend
# Desarrollo:  http://localhost:5000/api
# Producción:  https://tools-autorx.onrender.com/api
REACT_APP_API_URL=http://localhost:5000/api

# Firebase — obtén estos valores en:
# Firebase Console → tu proyecto → Configuración del proyecto → Tus apps
REACT_APP_FIREBASE_API_KEY=tu_api_key_aqui
REACT_APP_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=tu-proyecto-id
REACT_APP_FIREBASE_STORAGE_BUCKET=tu-proyecto.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=123456789
REACT_APP_FIREBASE_APP_ID=1:123456789:web:abcdef123456
